{
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.json",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.svg",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.png",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.jpeg",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.gif",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.ico",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/login.html"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/workers",
      "dest": "/workers.html"
    },
    {
      "src": "/recruiters",
      "dest": "/recruiters.html"
    },
    {
      "src": "/jobs",
      "dest": "/jobs.html"
    },
    {
      "src": "/requests",
      "dest": "/requests.html"
    },
    {
      "src": "/analytics",
      "dest": "/analytics.html"
    },
    {
      "src": "/recruiter-dashboard",
      "dest": "/recruiter-dashboard.html"
    },
    {
      "src": "/admin-profile",
      "dest": "/admin-profile.html"
    }
  ]
}
